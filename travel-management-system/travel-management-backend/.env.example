# VoyaGo™ Backend Configuration (Production Template)

# 1. Server Configuration
PORT=5000
NODE_ENV=production
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://voyago-travel.onrender.com

# 2. Database (MongoDB Atlas URL)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/voyago?retryWrites=true&w=majority

# 3. Security (JWT)
JWT_SECRET=use_a_long_random_string_here_for_production_security

# 4. Email Service (For Confirmations)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# 5. Travel APIs (Optional - for real-world integration)
AMADEUS_API_KEY=your_key
AMADEUS_API_SECRET=your_secret
