# VoyaGo™ Frontend Environment Configuration
# VoyaGo Technologies Pvt. Ltd.
# -----------------------------------------------
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control

# Backend API URL — change to your deployed URL in production
VITE_API_URL=http://localhost:5000

# App Metadata
VITE_APP_NAME=VoyaGo
VITE_APP_VERSION=2.0.0
VITE_APP_TAGLINE=Your World. Your Journey. Reimagined.
VITE_COMPANY_NAME=VoyaGo Technologies Pvt. Ltd.

# Feature Flags
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_LIVE_TRACKING=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_APK_DOWNLOAD=true

# Analytics (optional — add your keys here)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_HOTJAR_ID=XXXXXXX

# Mapbox / Leaflet (for live tracking and trip planner)
# VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxx
